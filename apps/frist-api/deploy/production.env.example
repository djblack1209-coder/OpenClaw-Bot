NODE_ENV=production
FRIST_API_PUBLIC_MODE=1
FRIST_API_ADMIN_TOKEN=replace-with-a-long-random-admin-token
FRIST_API_ADMIN_PAGE_CODE=replace-with-hidden-admin-entry-code
FRIST_API_ADMIN_CLAIM_CODES=replace-with-one-time-owner-claim-code
FRIST_API_SESSION_SECRET=replace-with-a-long-random-session-secret
FRIST_API_DATA_ENCRYPTION_KEY=replace-with-a-long-random-runtime-encryption-key
FRIST_API_PUBLIC_GATEWAY_BASE_URL=https://api.example.com/v1
FRIST_API_ALLOW_INSECURE_PUBLIC_HTTP=0
FRIST_API_PROBE_TIMEOUT_MS=2500
FRIST_API_ALLOW_DEMO_RECHARGE=0
FRIST_API_EXPOSE_VERIFICATION_CODE=0
FRIST_API_REQUIRE_CAPTCHA=1
FRIST_API_CAPTCHA_MAX_ATTEMPTS=3
FRIST_API_PASSWORD_RESET_TTL_MS=900000
FRIST_API_AUTH_RATE_LIMIT_MAX=20
FRIST_API_AUTH_RATE_LIMIT_WINDOW_MS=60000
FRIST_API_LOW_INVENTORY_WEBHOOK=
FRIST_API_SMTP_HOST=smtp.example.com
FRIST_API_SMTP_PORT=465
FRIST_API_SMTP_SECURE=1
FRIST_API_SMTP_FAMILY=auto
FRIST_API_SMTP_USER=alerts@example.com
FRIST_API_SMTP_PASSWORD=replace-with-mail-app-password
FRIST_API_SMTP_FROM=alerts@example.com
FRIST_API_BALANCE_ALERT_FROM_NAME=Frist-API Billing
FRIST_API_PAYMENT_ENABLED=0
FRIST_API_WECHAT_PAY_ENABLED=0
FRIST_API_WECHAT_PAY_APPID=replace-after-wechat-merchant-registration
FRIST_API_WECHAT_PAY_MCH_ID=replace-after-wechat-merchant-registration
FRIST_API_WECHAT_PAY_SERIAL_NO=replace-with-wechat-api-cert-serial
FRIST_API_WECHAT_PAY_PRIVATE_KEY=replace-with-wechat-merchant-private-key
FRIST_API_WECHAT_PAY_PUBLIC_KEY=replace-with-wechat-platform-public-key
FRIST_API_WECHAT_PAY_API_V3_KEY=replace-with-32-byte-wechat-api-v3-key
FRIST_API_WECHAT_PAY_NOTIFY_URL=https://api.example.com/api/frist/payments/wechat/notify
FRIST_API_ALIPAY_ENABLED=0
FRIST_API_ALIPAY_APP_ID=replace-after-alipay-app-registration
FRIST_API_ALIPAY_PRIVATE_KEY=replace-with-alipay-app-private-key
FRIST_API_ALIPAY_PUBLIC_KEY=replace-with-alipay-public-key
FRIST_API_ALIPAY_NOTIFY_URL=https://api.example.com/api/frist/payments/alipay/notify
FRIST_API_NEWAPI_ENABLED=0
FRIST_API_NEWAPI_BASE_URL=http://openclaw-newapi:3000
FRIST_API_NEWAPI_ACCESS_TOKEN=replace-with-new-api-user-access-token
FRIST_API_NEWAPI_USER_ID=1
FRIST_API_NEWAPI_DEFAULT_GROUP=default
FRIST_API_NEWAPI_DEFAULT_TOKEN_QUOTA=0
FRIST_API_NEWAPI_GATEWAY_ENABLED=0
FRIST_API_NEWAPI_GATEWAY_BASE_URL=http://openclaw-newapi:3000/v1
