GPT_API_FREE_BASE_URL=

# ========== 搜索/工具 API ==========

# SerpApi — 搜索引擎API (免费250次/月, 50次/小时)
SERPAPI_KEY=

# Brave Search API — 网页搜索 (免费$5/月≈1000次, 50QPS)
BRAVE_SEARCH_API_KEY=

# CloudConvert — 文件格式转换 (https://cloudconvert.com)
CLOUDCONVERT_API_KEY=

# ========== 硅基流动付费Key池 (未实名, 每条14元余额) ==========
# ⚠️ 禁止调用名称含 "Pro" 的模型，否则403报错！仅限非Pro模型：
#   DeepSeek-R1 (非Pro, ~175次/key), DeepSeek-V3 (非Pro, ~1000次/key),
#   Qwen3-235B-A22B, GLM-4-32B-0414 等免费模型 (不扣余额)
# 10条Key，总余额约140元，按 DeepSeek-R1 约5000tok/次计算
SILICONFLOW_PAID_KEYS=
SILICONFLOW_PAID_BASE_URL=

# ========== 搬运模块激活配置 ==========
# 以下模块代码已就绪、依赖已安装，设置对应 Key 即可自动激活

# Tavily AI 搜索 (购物比价/深度研究) — https://tavily.com (免费 1000次/月)
# 被 brain.py 购物比价引擎 + agent_tools.py 引用
TAVILY_API_KEY=

# Langfuse LLM 可观测 (追踪/调试/成本分析) — https://langfuse.com (免费 50K events/月)
# 被 api_mixin.py + execution/_ai.py 引用，LiteLLM callback 自动上报
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=

# 微信通知桥接 — 将所有系统通知同步到微信
# 凭证自动从 .openclaw/openclaw-weixin/accounts/ 读取
WECHAT_NOTIFY_ENABLED=

# ========== New-API 网关 (LLM 渠道管理) ==========
# Docker 部署: docker compose -f docker-compose.newapi.yml up -d
# 管理后台: http://localhost:3000
NEWAPI_BASE_URL=http://localhost:3000
NEWAPI_ADMIN_TOKEN=
