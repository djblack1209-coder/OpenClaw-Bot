# ==========================================
# ClawBot 配置文件 v7.0 - 7 Bot 免费优先架构
# ==========================================

# ========== 内控 API 认证 ==========
# 设置后所有 FastAPI 端点需带 Header: X-API-Token: <token>
# WebSocket 使用 query param: ?token=<token>
# 留空 = 无认证模式 (仅限开发环境, 生产必须设置!)
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
OPENCLAW_API_TOKEN=

# ========== API 配置 ==========

# 硅基流动 API Keys (多个用逗号分隔, 免费无限)
SILICONFLOW_KEYS=
SILICONFLOW_BASE_URL=

# Claude 代理 API (仅显式 /claude 调用; 不再允许走 XAPI 等空余额中转)
CLAUDE_API_KEY=
CLAUDE_BASE_URL=
CLAUDE_MODEL=

# g4f 本地 API (完全免费, 端口18891)
G4F_BASE_URL=http://127.0.0.1:18891/v1
G4F_API_KEY=dummy

# Kiro Gateway (免费Claude, 端口18793)
KIRO_BASE_URL=
KIRO_API_KEY=

# 智谱 GLM-OCR API (文字识别)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=

# ========== 免费 API 池配置 ==========
# 以下 Key 为空时对应源自动跳过，不影响系统运行
# 获取方式参考: https://github.com/cheahjs/free-llm-api-resources

# OpenRouter (免费:free模型 20RPM, 无充值50RPD/有充值1000RPD)
OPENROUTER_API_KEY=

# Groq (极速推理, 模型不同限制不同: kimi-k2 60RPM/1000RPD, llama-70b 30RPM/1000RPD, 8b 30RPM/14400RPD)
GROQ_API_KEY=

# Cerebras (免费高速推理, 当前接入 gpt-oss-120b / llama3.1-8b, 30RPM)
CEREBRAS_API_KEY=

# Google AI Studio (Gemini 免费, 2.0系已废弃→统一使用 2.5/3.x 系)
GEMINI_API_KEY=

# Mistral (免费层限流严格, 仅作中后位兜底, 数据可能用于训练)
MISTRAL_API_KEY=

# Cohere (1000次/月, 20RPM, 仅作中后位兜底)
COHERE_API_KEY=

# GitHub Models (需要 Copilot 或 GitHub Token)
GITHUB_MODELS_TOKEN=

# NVIDIA NIM (信用额度制, 非真正无限, 试用额度用完需购买 AI Enterprise)
NVIDIA_NIM_API_KEY=

# Sambanova (免费试用)
SAMBANOVA_API_KEY=

# ========== Telegram Bot Tokens (7个Bot) ==========

# Bot 1: Qwen 235B - 全能主力 (免费: SiliconFlow/g4f, 真实模型: qwen-3-235b)
QWEN235B_TOKEN=your-telegram-bot-token
QWEN235B_USERNAME=

# Bot 2: GPT-OSS - 快速副手 (免费: g4f/免费池, 真实模型: gpt-oss-120b)
GPTOSS_TOKEN=
GPTOSS_USERNAME=

# Bot 3: Claude Sonnet - 最强大脑 (免费: g4f/Kiro, 真实模型: Claude Sonnet 4.5)
CLAUDE_SONNET_TOKEN=
CLAUDE_SONNET_USERNAME=

# Bot 4: Claude Haiku - 闪电快手 (免费: g4f/免费池, 真实模型: Claude Haiku 4.5)
CLAUDE_HAIKU_TOKEN=
CLAUDE_HAIKU_USERNAME=

# Bot 5: DeepSeek V3.2 - 中文之王 (免费: g4f/SiliconFlow, 真实模型: DeepSeek-V3.2)
DEEPSEEK_V3_TOKEN=your-telegram-bot-token
DEEPSEEK_V3_USERNAME=

# Bot 6: Claude Opus - 终极大脑 (免费优先/私聊付费兜底, 真实模型: Claude Opus 4.5)
CLAUDE_OPUS_TOKEN=
CLAUDE_OPUS_USERNAME=

# Bot 7: Free LLM - 免费万能助手 (免费池轮询, 最强免费模型自动选择)
FREE_LLM_TOKEN=
FREE_LLM_USERNAME=

# ========== 安全配置 ==========

# Docker Redis 密码。生产环境必须设置为随机强密码。
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=

# 允许使用的 Telegram 用户 ID
ALLOWED_USER_IDS=

# ========== 其他配置 ==========

# 交易播报通知目标（群组 chat_id，负数）
NOTIFY_CHAT_ID=
PRIVATE_NOTIFY_CHAT_ID=

