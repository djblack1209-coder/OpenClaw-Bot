# ============================================================
# OpenClaw Bot 夜间自动审计 — 配置文件
# 复制为 config.env 并填入真实值：
#   cp config.env.example config.env
#   vim config.env
# ============================================================

# === API 配置 ===
# Anthropic API 密钥（或第三方兼容提供商的密钥）
ANTHROPIC_API_KEY="sk-your-api-key-here"

# 如果使用第三方 API 提供商（如中转站），填写其 base URL
# 留空则使用 Anthropic 官方 API
ANTHROPIC_BASE_URL=""

# 模型名称（sonnet 性价比高，opus 深度分析更强）
# 如果使用第三方提供商，填写该提供商支持的模型标识符
MODEL="sonnet"

# === 路径配置 ===
# 项目根目录（绝对路径）
PROJECT_DIR="/Users/blackdj/Desktop/OpenClaw Bot"

# Claude Code 可执行文件路径
CLAUDE_BIN="/usr/local/bin/claude"

# === 预算控制 ===
# 每个阶段最大花费（美元），超过则中止该阶段
BUDGET_PER_PHASE="5.00"

# 整晚最大总花费（美元），超过则停止所有后续阶段
MAX_TOTAL_BUDGET="25.00"

# === 时间窗口（中国标准时间 UTC+8）===
# 开始时间（24小时制，0=午夜）
START_HOUR_CST=0

# 结束时间（到此时间强制停止）
END_HOUR_CST=8

# 单阶段最少剩余时间（分钟），不足则跳过
MIN_REMAINING_MINUTES=30

# === Git 配置 ===
# 是否在审计结束后自动 push
AUTO_PUSH="true"

# 远程分支名
GIT_REMOTE="origin"
GIT_BRANCH="main"

# === 通知配置（可选）===
# Telegram Bot Token（用于发送审计完成通知）
# 留空则不发送通知
NOTIFY_TG_BOT_TOKEN=""
NOTIFY_TG_CHAT_ID=""

# === 高级配置 ===
# 每阶段最大"继续"轮数（上下文满了后自动续接）
MAX_CONTINUATIONS=3

# 每阶段最大 agentic 轮次（防止无限循环，Claude Code 官方参数）
MAX_TURNS_PER_PHASE=200

# 备用模型（主模型过载时自动切换，Claude Code 官方参数）
# 留空则不启用备用模型
FALLBACK_MODEL=""

# 是否保留详细日志（true=保留所有输出，false=仅保留摘要）
KEEP_VERBOSE_LOGS="true"

# Mac 防休眠（仅 macOS 有效）
PREVENT_SLEEP="true"

# 审计完成后是否让 Mac 进入休眠（仅 macOS 有效）
# 适用于不想让 Mac 整夜开着的场景
SLEEP_AFTER_AUDIT="false"

# 审计完成后是否自动发起下一轮（用于多轮深度审计）
AUTO_NEXT_ROUND="false"

# === 增量审计 ===
# 开启后只审计自上次审计以来变更的文件（省时省钱）
# 关闭则每次全量扫描（更彻底但更贵）
INCREMENTAL_AUDIT="false"

# === 日志管理 ===
# 日志保留天数（超过此天数的旧日志自动清理）
LOG_RETENTION_DAYS=30

# === 安全限制 ===
# 单阶段最大允许修改的文件数（超过则告警，防止 AI 一次改太多）
MAX_CHANGED_FILES_PER_PHASE=30

# === 阶段总数 ===
# 默认 8 个阶段（1安全 2后端 3集成 4前端 5架构 6文档 7数据交易 8端到端）
# 如果只想跑前 6 个经典阶段，改为 6
TOTAL_PHASES=8

# === 多项目联动通知（可选）===
# 如果 Mac 上还有其他项目也跑夜间审计，可以在这里配置
# 审计完成后的 Telegram 通知会同时附带这些项目的评分/状态
#
# 格式: "项目名:日志目录;项目名:日志目录;..."（分号分隔）
# 每个项目用 "项目名:日志目录" 表示，多个项目间用分号 ; 隔开
# 日志目录需要是绝对路径，指向该项目的审计日志根目录
#
# 支持两种评分文件格式:
#   1. 有 health-score.json 的项目 → 显示分数和评级
#   2. 只有 summary.md 的项目 → 显示"有审计报告（无评分）"
#
# 示例（3个项目）:
# SIBLING_PROJECTS="AI Bridge:/path/to/ai-bridge/logs/nightly-audit;EXAM-MASTER:/path/to/exam/logs/nightly-audit;像素回环:/path/to/pixel/audit-reports"
SIBLING_PROJECTS=""

# === 统一通知服务（可选）===
# 审计完成后，用 Qwen AI 生成一份排版统一的全项目日报推送到 Telegram
# 需要一个支持 OpenAI 兼容 API 的 Qwen 服务（如 SiliconFlow、iflow 等）
# 留空则统一通知服务不使用 AI 生成（降级为模板模式）
QWEN_API_URL="https://api.siliconflow.cn/v1/chat/completions"
QWEN_API_KEY=""
QWEN_MODEL="Qwen/Qwen3-235B-A22B-Instruct-2507"
