<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.openclaw.keepawake</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>while true; do PID="$(pgrep -f 'openclaw-manager|openclaw-gateway|multi_main.py' | head -n 1 || true)"; if [[ -n "$PID" ]]; then /usr/bin/caffeinate -dimsu -w "$PID"; else sleep 10; fi; done</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/blackdj/.openclaw/logs/com-openclaw-keepawake.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/blackdj/.openclaw/logs/com-openclaw-keepawake.stderr.log</string>
</dict>
</plist>
