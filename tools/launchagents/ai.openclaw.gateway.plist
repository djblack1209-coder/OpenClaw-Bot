<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.openclaw.gateway</string>
    
    <key>Comment</key>
    <string>OpenClaw Gateway (v2026.3.2)</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
      <key>SuccessfulExit</key>
      <false/>
    </dict>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>Umask</key>
    <integer>63</integer>
    <!-- 内联启动命令：macOS 26+ Sandbox 策略禁止 bash 读取带 provenance 属性的脚本文件，必须把命令内联到 -c 参数中 -->
    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>-c</string>
      <string>exec /opt/homebrew/opt/node/bin/node /Users/blackdj/.npm-global/lib/node_modules/openclaw/dist/index.js gateway --port 18789</string>
    </array>
    
    <!-- 日志路径必须在 ~/Library/Logs/ 下：macOS 26+ Sandbox 策略禁止 xpcproxy 读取带 provenance 属性的项目目录下的文件 -->
    <key>StandardOutPath</key>
    <string>/Users/blackdj/Library/Logs/OpenClaw/gateway.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/blackdj/Library/Logs/OpenClaw/gateway.stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
    <key>HOME</key>
    <string>/Users/blackdj</string>
    <key>TMPDIR</key>
    <string>/var/folders/fh/ktq7clz11v36qpdbt63rxtj00000gn/T/</string>
    <key>PATH</key>
    <string>/Users/blackdj/.local/bin:/Users/blackdj/.npm-global/bin:/Users/blackdj/bin:/Users/blackdj/.volta/bin:/Users/blackdj/.asdf/shims:/Users/blackdj/.bun/bin:/Users/blackdj/Library/Application Support/fnm/aliases/default/bin:/Users/blackdj/.fnm/aliases/default/bin:/Users/blackdj/Library/pnpm:/Users/blackdj/.local/share/pnpm:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>NO_PROXY</key>
    <string>127.0.0.1,localhost,::1</string>
    <key>no_proxy</key>
    <string>127.0.0.1,localhost,::1</string>
    <key>NODE_EXTRA_CA_CERTS</key>
    <string>/etc/ssl/cert.pem</string>
    <key>NODE_USE_SYSTEM_CA</key>
    <string>1</string>
    <key>OPENCLAW_STATE_DIR</key>
    <string>/Users/blackdj/Desktop/OpenEverything/.openclaw</string>
    <key>OPENCLAW_CONFIG_PATH</key>
    <string>/Users/blackdj/Desktop/OpenEverything/.openclaw/openclaw.json</string>
    <key>OPENCLAW_GATEWAY_PORT</key>
    <string>18789</string>
    <!-- 安全加固(HI-590): 必须在加载 LaunchAgent 前设置强随机 token，禁止使用弱默认值 -->
    <!-- 生成方法: openssl rand -hex 32 > ~/.openclaw/gateway_token -->
    <key>OPENCLAW_GATEWAY_TOKEN</key>
    <string></string>
    <key>OPENCLAW_LAUNCHD_LABEL</key>
    <string>ai.openclaw.gateway</string>
    <key>OPENCLAW_SYSTEMD_UNIT</key>
    <string>openclaw-gateway.service</string>
    <key>OPENCLAW_SERVICE_MARKER</key>
    <string>openclaw</string>
    <key>OPENCLAW_SERVICE_KIND</key>
    <string>gateway</string>
    <key>OPENCLAW_SERVICE_VERSION</key>
    <string>2026.3.2</string>
    </dict>
  </dict>
</plist>
